{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Cassandra": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379",
    "ClickHouse": "Host=localhost;Port=8123;Database=ad_insights;Username=default;Password="
  },
  "Cassandra": {
    "ContactPoints": [ "localhost" ],
    "Port": 9042,
    "Keyspace": "ad_insights",
    "Username": "",
    "Password": ""
  },
  "Jwt": {
    "Issuer": "https://auth.adinsights.io",
    "Audience": "adinsights-api",
    "Key": "REPLACE_WITH_SECURE_256_BIT_KEY_IN_VAULT_OR_ENV"
  },
  "Jaeger": {
    "Host": "localhost",
    "Port": 6831
  },
  "AllowedHosts": "*"
}
