{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "Jwt": {
    "Issuer": "https://auth.adinsights.io",
    "Audience": "adinsights-api",
    "Key": "REPLACE_WITH_SECURE_256_BIT_KEY_IN_VAULT_OR_ENV"
  },
  "AllowedHosts": "*"
}
